# Copy this file to .env and fill in real values.
# .env is only used with docker-compose.yml / a local dotenv-style workflow;
# Spring Boot itself reads these as plain environment variables (see
# src/main/resources/application.yml for how each one is consumed and its
# default, if any).

# --- MySQL -------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3306/gemblog_pro?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=changeme
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- JWT -----------------------------------------------------------------
# Required, no default. Must be >= 32 bytes once UTF-8 encoded (HS256).
# Generate one with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION_DAYS=7

# --- ImageKit (https://imagekit.io) --------------------------------------
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# --- Gemini (https://ai.google.dev) --------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- App -------------------------------------------------------------------
PORT=8080
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
JPA_SHOW_SQL=false
